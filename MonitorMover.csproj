<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>MonitorMover</AssemblyName>
    <RootNamespace>MonitorMover</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <Product>MonitorMover</Product>
    <!-- Marketing version: bump the first three parts when the changelog gains an entry. -->
    <VersionPrefix>1.1.4</VersionPrefix>
    <!-- Wildcard build/revision auto-changes on every build (needs Deterministic=false),
         so the About box shows a distinct version per build. -->
    <AssemblyVersion>1.1.*</AssemblyVersion>
    <Deterministic>false</Deterministic>
    <FileVersion>1.1.0.0</FileVersion>
  </PropertyGroup>

</Project>
